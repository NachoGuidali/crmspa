# === Django ===
# En producción, SECRET_KEY NO puede empezar con "django-insecure" (el arranque falla).
# Generá uno con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me
DEBUG=True
# En el VPS: el CRM vive en crm.spacuatroestaciones.com (la web pública es estática, no Django).
# ALLOWED_HOSTS=crm.spacuatroestaciones.com
ALLOWED_HOSTS=localhost,127.0.0.1

# === Base de datos (PostgreSQL) ===
# Corriendo Django en el host contra la DB dockerizada, el puerto es 5435 (ver docker-compose).
# Dentro del contenedor web, docker-compose sobreescribe DB_HOST=db y DB_PORT=5432.
DB_NAME=crmspa
DB_USER=crmspa
DB_PASSWORD=crmspa
DB_HOST=localhost
DB_PORT=5435

# === Redis / Celery ===
# En el host contra Redis dockerizado, el puerto es 6380. El contenedor usa redis://redis:6379/0.
REDIS_URL=redis://localhost:6380/0

# === Evolution API (gateway de WhatsApp) ===
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=crmspa

# === n8n ===
# URL del webhook de n8n al que el CRM reenvía los mensajes entrantes.
N8N_WEBHOOK_URL=
# URL del webhook de n8n que el CRM llama al confirmar/aprobar una reserva
# (para que el bot le mande la confirmación final al cliente). Ej:
# https://n8n.tu-dominio/webhook/reserva-aprobada
N8N_RESERVA_APROBADA_URL=

# === Seguridad (producción) ===
# CSRF: el dominio del CRM (con https). Ej:
# CSRF_TRUSTED_ORIGINS=https://crm.spacuatroestaciones.com
CSRF_TRUSTED_ORIGINS=
# CORS: la web pública consume la API de precios del CRM (cross-origin). Autorizá su dominio:
# CORS_ALLOWED_ORIGINS=https://spacuatroestaciones.com,https://www.spacuatroestaciones.com
CORS_ALLOWED_ORIGINS=

# === Rate limiting (opcional, valores por defecto) ===
THROTTLE_ANON=120/min
THROTTLE_USER=300/min
THROTTLE_WEBHOOK=600/min
